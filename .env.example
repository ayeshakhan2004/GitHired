# ============================================
# Githired — Environment Variables
# Copy this to .env.local and fill in your keys
# ============================================

# REQUIRED: Google Gemini API Key
# Get yours FREE at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL: GitHub Personal Access Token
# Raises rate limit from 60/hr to 5000/hr
# Create at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=your_github_token_here

# OPTIONAL: LinkedIn via LinkFinder AI
# Get your key at https://linkfinderai.com
# If not set, LinkedIn section will be skipped
# Get your key at: https://linkfinderai.com
LINKFINDER_API_KEY=your_linkfinder_api_key_here
